// ClaudeMonitor overlay — pixel-perfect parity with Python (usage_monitor.py).
//
// Column widths and paddings match `_COL_*` constants from the Python source
// exactly so the two windows can be placed side-by-side and compared visually.

// ─────────────────────────── data structures ────────────────────────────────

export struct MetricView {
    pct: float,
    pct-text: string,       // "85%" or ""
    reset-text: string,     // "1ч 23м" / "3д 4ч" / ""
    color: color,
    has-data: bool,
}

export struct AccountView {
    id: string,
    login: string,           // pre-truncated to 6 chars + "…"
    login-full: string,      // tooltip
    plan: string,
    plan-color: color,
    five-hour: MetricView,
    seven-day: MetricView,
    seven-day-design: MetricView,
    is-active: bool,
}

export struct StatusView {
    text: string,
    error: bool,
}

// ─────────────────────────── reusable bits ──────────────────────────────────

component MetricCell inherits Rectangle {
    in property <MetricView> metric;
    in property <length> col-width: 60px;
    width: col-width;
    background: transparent;
    VerticalLayout {
        padding-left: 0px;
        alignment: center;
        spacing: 1px;
        Text {
            width: 100%;
            text: metric.has-data ? metric.pct-text : "…";
            color: metric.has-data ? metric.color : #555555;
            horizontal-alignment: left;
            font-size: 13px;
            font-weight: 600;
        }
        Text {
            width: 100%;
            text: metric.has-data ? metric.reset-text : "";
            color: #888888;
            horizontal-alignment: left;
            font-size: 11px;
        }
    }
}

component CheckCircle inherits Rectangle {
    in property <bool> active;
    in property <bool> hovered;
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border-width: 1.5px;
    border-color: active ? #10b981 : (hovered ? #4ade80 : #3a3a4a);
    background: active ? #10b981 : (hovered ? rgba(74, 222, 128, 0.06) : transparent);

    if active : Path {
        x: 0px; y: 0px;
        width: parent.width;
        height: parent.height;
        stroke: #ffffff;
        stroke-width: 2px;
        fill: transparent;
        commands: "M 4.5 8 L 7 11 L 12 5";
    }
}

component AccountRow inherits Rectangle {
    in property <AccountView> account;

    callback row-right-clicked(length /* x */, length /* y */);
    callback chk-clicked();
    // Fires when user starts dragging on the row (anywhere except chk circle).
    // The row's full-area TouchArea below consumes left-clicks, so the outer
    // drag_root never sees them — we have to forward the drag intent here.
    callback row-drag-start();

    height: 38px;
    // Active row gets the highlight; no row-wide hover (per user spec).
    background: account.is-active ? #1a1a26 : transparent;
    border-radius: 4px;

    // Tooltip is shown when the cursor hovers the name column (x ∈ [30, 110]).
    // Coordinates relative to AccountRow: 4 (padding) + 22 (chk) + 4 (gap) = 30,
    // plus 80 width = 110.
    property <bool> show-name-tooltip: rmenu_touch.has-hover
        && rmenu_touch.mouse-x >= 30px
        && rmenu_touch.mouse-x < 110px
        && account.login-full != "";

    rmenu_touch := TouchArea {
        pointer-event(ev) => {
            if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                root.row-drag-start();
            }
            if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.up) {
                root.row-right-clicked(self.mouse-x, self.mouse-y);
            }
        }
    }

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        padding-top: 3px;
        padding-bottom: 3px;
        spacing: 0px;

        // CHK column (22). Only this TouchArea can switch the active account.
        Rectangle {
            width: 22px;
            chk_touch := TouchArea {
                width: 18px; height: 18px;
                x: 2px;
                y: (parent.height - 18px) / 2;
                clicked => { root.chk-clicked(); }
                
                CheckCircle {
                    x: 1px; y: 1px;
                    active: account.is-active;
                    hovered: chk_touch.has-hover;
                }
            }
        }
        Rectangle { width: 4px; }

        // NAME: 80 wide, just clipped (no ellipsis). Tooltip with the full email
        // shows when the row's TouchArea reports a hover within this column's
        // x-range — that way we don't add a TouchArea that would block drag.
        Rectangle {
            width: 80px;
            clip: true;
            Text {
                width: 100%;
                text: account.login;
                color: account.is-active ? #e8e8e8 : #bbbbbb;
                font-size: 12px;
                font-weight: account.is-active ? 600 : 400;
                vertical-alignment: center;
                horizontal-alignment: left;
                overflow: clip;
            }
        }

        // PLAN: 42 wide
        Rectangle {
            width: 42px;
            Text {
                width: 100%;
                text: account.plan;
                color: account.plan-color;
                font-size: 11px;
                vertical-alignment: center;
                horizontal-alignment: left;
            }
        }

        // Three metric cells with ABSOLUTE positioning of two Texts inside.
        // We hit a Slint VerticalLayout bug where layout_cache for 2nd and 3rd
        // identical cells produced height=0 → texts invisible. Switching to
        // absolute x/y avoids the layout engine entirely for these cells.
        // Cells: explicit 32px height (= row height 38 - top/bottom padding 3+3),
        // texts at fixed y so the row is fully predictable and stops growing.
        Rectangle {
            width: 60px; height: 32px; background: transparent;
            Text {
                x: 0; y: 1px; width: 60px; height: 16px;
                text: account.five-hour.has-data ? account.five-hour.pct-text : "…";
                color: account.five-hour.has-data ? account.five-hour.color : #555555;
                horizontal-alignment: left; vertical-alignment: center;
                font-size: 13px; font-weight: 600;
            }
            Text {
                x: 0; y: 17px; width: 60px; height: 14px;
                text: account.five-hour.has-data ? account.five-hour.reset-text : "";
                color: #888888; horizontal-alignment: left; vertical-alignment: center;
                font-size: 11px;
            }
        }
        Rectangle {
            width: 60px; height: 32px; background: transparent;
            Text {
                x: 0; y: 1px; width: 60px; height: 16px;
                text: account.seven-day.has-data ? account.seven-day.pct-text : "…";
                color: account.seven-day.has-data ? account.seven-day.color : #555555;
                horizontal-alignment: left; vertical-alignment: center;
                font-size: 13px; font-weight: 600;
            }
            Text {
                x: 0; y: 17px; width: 60px; height: 14px;
                text: account.seven-day.has-data ? account.seven-day.reset-text : "";
                color: #888888; horizontal-alignment: left; vertical-alignment: center;
                font-size: 11px;
            }
        }
        Rectangle {
            width: 60px; height: 32px; background: transparent;
            Text {
                x: 0; y: 1px; width: 60px; height: 16px;
                text: account.seven-day-design.has-data ? account.seven-day-design.pct-text : "…";
                color: account.seven-day-design.has-data ? account.seven-day-design.color : #555555;
                horizontal-alignment: left; vertical-alignment: center;
                font-size: 13px; font-weight: 600;
            }
            Text {
                x: 0; y: 17px; width: 60px; height: 14px;
                text: account.seven-day-design.has-data ? account.seven-day-design.reset-text : "";
                color: #888888; horizontal-alignment: left; vertical-alignment: center;
                font-size: 11px;
            }
        }
    }

    // Hover tooltip for the truncated login name. Sits above the row so it
    // never overlaps the row's own content. Width follows the text.
    if show-name-tooltip : Rectangle {
        x: 30px;
        y: -22px;
        height: 20px;
        background: #1a1a1a;
        border-color: #333;
        border-width: 1px;
        border-radius: 3px;
        drop-shadow-blur: 6px;
        drop-shadow-color: rgba(0, 0, 0, 0.6);
        width: tooltip_text.preferred-width + 14px;
        tooltip_text := Text {
            x: 7px; y: 0;
            height: parent.height;
            text: account.login-full;
            color: #dddddd;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

// ─────────────────────────── header buttons ─────────────────────────────────

component HeaderButton inherits Rectangle {
    in property <string> glyph;
    in property <color> hover-color: #ffffff;
    in property <length> font-size: 13px;
    callback clicked();
    width: 16px; height: 16px;
    background: transparent;
    touch := TouchArea {
        
        clicked => { root.clicked(); }
    }
    Text {
        text: glyph;
        color: touch.has-hover ? hover-color : #cccccc;
        font-family: "Segoe UI Symbol";
        font-size: root.font-size;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// ─────────────────────────── popup menu items ───────────────────────────────

// ─────────────────────────── small checkbox ────────────────────────────────

component TinyCheckBox inherits Rectangle {
    in property <bool> checked;
    in property <string> text;
    callback toggled();
    height: 16px;
    background: transparent;

    HorizontalLayout {
        spacing: 6px;
        alignment: start;
        Rectangle {
            width: 12px; height: 12px;
            y: (parent.height - 12px) / 2;
            border-width: 1px;
            border-color: root.checked ? #4ade80 : #555555;
            border-radius: 2px;
            background: root.checked ? #1a3a26 : transparent;
            if root.checked : Path {
                x: 0px; y: 0px;
                width: 12px; height: 12px;
                stroke: #4ade80;
                stroke-width: 1.5px;
                fill: transparent;
                commands: "M 2.5 6 L 5 8.5 L 9 4";
            }
        }
        Text {
            text: root.text;
            color: #888888;
            font-size: 10px;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        
        clicked => { root.toggled(); }
    }
}

component MenuRow inherits Rectangle {
    in property <string> label;
    in property <bool> separator: false;
    in property <bool> disabled: false;
    callback activated();
    height: separator ? 7px : 22px;
    background: touch.has-hover && !disabled && !separator ? #333333 : #1a1a1a;

    if !separator : Text {
        x: 10px;
        text: label;
        color: disabled ? #555555 : #cccccc;
        font-size: 11px;
        vertical-alignment: center;
    }
    if separator : Rectangle {
        x: 6px;
        y: 3px;
        width: parent.width - 12px;
        height: 1px;
        background: #333333;
    }

    touch := TouchArea {
        mouse-cursor: default;
        clicked => {
            if (!separator && !disabled) {
                root.activated();
            }
        }
    }
}

// ─────────────────────────── main window ────────────────────────────────────

export component AppWindow inherits Window {
    title: "ClaudeMonitor";
    background: transparent;
    no-frame: true;
    always-on-top: true;
    // Two-layer resize: Slint surface dims (here) and OS window dims (Rust
    // window().set_size()). Both must change in sync. The binding below
    // controls how big Slint thinks its drawing surface is — without it,
    // Slint keeps laying content out at 380×fullHeight and the right side
    // gets clipped after Rust shrinks the OS window.
    width: compact-mode ? 160px : 380px;
    preferred-height: compact-mode ? 36px : content_root.preferred-height + 10px;

    // ── data ───────────────────────────────────────────────
    in property <[AccountView]> accounts: [];
    in property <StatusView> status: { text: "", error: false };
    in property <bool> auto-switch-enabled: false;
    in property <bool> is-refreshing: false;
    in property <string> proxy-label: "Прокси: (не задан)";
    // Compact-mode toggle (clicked on header → enter, click on compact label → exit).
    in-out property <bool> compact-mode: false;
    // Pre-formatted "85% (1ч 23м)" string for the active account, computed in
    // Rust alongside accounts. "—" when no active account or no data.
    in property <string> compact-text: "—";

    // ── outbound callbacks ────────────────────────────────
    callback close-clicked();
    callback minimize-clicked();
    callback refresh-clicked();
    callback refresh-all-clicked();
    callback open-claude-status();
    callback add-account-clicked();
    callback row-activated(string /* id */);
    callback row-context(string /* id */, length /* x */, length /* y */);
    callback row-remove(string /* id */);
    callback toggle-auto-switch();
    callback relogin-clicked();
    callback configure-proxy-clicked();
    callback quit-clicked();
    callback drag-start();
    // Fired when the header status row is clicked (without drag) — switch to
    // compact view. Wired to an explicit TouchArea inside the status text rect.
    callback header-clicked();
    // Fired when the compact-mode % label is clicked (without drag) — return
    // to the full view. Rust handles drag suppression and resize.
    callback compact-exit-clicked();

    // ── popup state ───────────────────────────────────────
    property <bool> window-menu-open: false;
    property <length> window-menu-x: 0;
    property <length> window-menu-y: 0;
    property <bool> row-menu-open: false;
    property <length> row-menu-x: 0;
    property <length> row-menu-y: 0;
    property <string> row-menu-aid: "";
    property <bool> row-menu-active: false;
    property <bool> switch-submenu-open: false;

    // ── outer 5px transparent margin (matches QVBoxLayout(5,5,5,5)) ──
    Rectangle {
        x: 5px; y: 5px;
        width: parent.width - 10px;
        height: parent.height - 10px;
        background: rgba(12, 12, 18, 0.96);
        border-radius: 8px;
        border-width: 1px;
        border-color: #2a2a3a;

        // Bottom-of-the-z-stack drag catcher. Children declared after this in
        // content_root sit ABOVE in the z-order. Their TouchAreas (refresh /
        // min / close buttons, "+ Добавить", per-row chk circles, the
        // auto-switch checkbox) get clicks first; whatever they don't catch
        // (status text, plain account row text, empty space) bubbles down to
        // drag_root and starts a window drag.
        drag_root := TouchArea {
            width: 100%; height: 100%;
            pointer-event(ev) => {
                if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                    root.drag-start();
                }
                if (ev.button == PointerEventButton.right && ev.kind == PointerEventKind.up) {
                    root.window-menu-x = self.mouse-x;
                    root.window-menu-y = self.mouse-y;
                    root.window-menu-open = true;
                    root.row-menu-open = false;
                }
            }
        }

        content_root := VerticalLayout {
            visible: !root.compact-mode;
            padding-left: 10px; padding-right: 10px;
            padding-top: 7px; padding-bottom: 8px;
            spacing: 3px;
            alignment: start;

            // ── Header line: drag-handle (status text) + 3 buttons ──
            HorizontalLayout {
                spacing: 4px;
                alignment: stretch;
                // Status text. No TouchArea — drag/right-click bubbles down
                // to the outer drag_root catcher.
                Rectangle {
                    horizontal-stretch: 1;
                    height: 16px;
                    background: transparent;
                    Text {
                        width: 100%; height: 100%;
                        text: root.status.text;
                        color: root.status.error ? #f87171 : #999999;
                        font-size: 11px;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        overflow: elide;
                    }
                    // Click on the header status row → enter compact mode.
                    // pointer-event(down) starts the Win32 modal window drag
                    // immediately; if the user just taps without moving, Slint
                    // still fires `clicked` after release and we toggle compact.
                    header_touch := TouchArea {
                        pointer-event(ev) => {
                            if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                                root.drag-start();
                            }
                        }
                        clicked => { root.header-clicked(); }
                    }
                }
                // Refresh button — Image (SVG) rotated CW by a Timer-driven tick.
                // We avoid state-based `animate iteration-count: -1` because that
                // pattern keeps the UI thread busy producing infinite frames even
                // when no actual animation is needed, which can starve clicks.
                refresh_btn := Rectangle {
                    width: 16px; height: 16px;
                    background: transparent;
                    rb_touch := TouchArea {
                        
                        clicked => { root.refresh-clicked(); }
                    }
                    // 0..359 step 12 every 40ms = full turn ≈ 1.2s. Positive
                    // angle in Slint renders clockwise (screen-space, Y-down).
                    property <int> spin-tick: 0;
                    spin-timer := Timer {
                        interval: 40ms;
                        running: root.is-refreshing;
                        triggered => {
                            parent.spin-tick = parent.spin-tick + 12 >= 360
                                ? 0
                                : parent.spin-tick + 12;
                        }
                    }
                    // Glyph is 12x12 inside a 16x16 hit-box so the icon looks
                    // smaller (per spec) but the click target stays generous.
                    Image {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: 12px; height: 12px;
                        source: @image-url("refresh.svg");
                        colorize: root.is-refreshing
                            ? #60a5fa
                            : (rb_touch.has-hover ? #ffffff : #cccccc);
                        rotation-origin-x: self.width / 2;
                        rotation-origin-y: self.height / 2;
                        rotation-angle: parent.spin-tick * 1deg;
                    }
                }
                HeaderButton {
                    glyph: "–";
                    clicked => { root.minimize-clicked(); }
                }
                HeaderButton {
                    glyph: "✕";
                    font-size: 12px;
                    hover-color: #f87171;
                    clicked => { root.close-clicked(); }
                }
            }

            // ── Top separator above "Аккаунты" ──────────
            Rectangle {
                height: 1px;
                background: #2a2a2a;
            }

            // ── Section header: "Аккаунты" + "+ Добавить" ─
            HorizontalLayout {
                spacing: 4px;
                Text {
                    text: "АККАУНТЫ";
                    color: #888888;
                    font-size: 9px;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                add_touch := TouchArea {
                    width: 76px; height: 18px;
                    
                    clicked => { root.add-account-clicked(); }
                    Rectangle {
                        background: add_touch.has-hover ? #2d5a8e : #1e3a5f;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: #2d5a8e;
                        Text {
                            text: "+ Добавить";
                            color: #60a5fa;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // ── Column headers (paddings + widths IDENTICAL to AccountRow) ─
            HorizontalLayout {
                padding-left: 4px; padding-right: 4px;
                spacing: 0px;
                Rectangle { width: 22px; }
                Rectangle { width: 4px; }
                Rectangle { width: 80px; Text { width: 100%; text: "Логин";    color: #888888; font-size: 10px; horizontal-alignment: left; } }
                Rectangle { width: 42px; Text { width: 100%; text: "Тариф";    color: #888888; font-size: 10px; horizontal-alignment: left; } }
                Rectangle { width: 60px; Text { width: 100%; text: "5ч сессия"; color: #888888; font-size: 10px; horizontal-alignment: left; } }
                Rectangle { width: 60px; Text { width: 100%; text: "7д лимит";  color: #888888; font-size: 10px; horizontal-alignment: left; } }
                Rectangle { width: 60px; Text { width: 100%; text: "7д Design"; color: #888888; font-size: 10px; horizontal-alignment: left; } }
            }

            // ── Account rows ───────────────────────────
            VerticalLayout {
                spacing: 1px;
                for acc in accounts : AccountRow {
                    account: acc;
                    chk-clicked => { root.row-activated(acc.id); }
                    row-drag-start => { root.drag-start(); }
                    row-right-clicked(rx, ry) => {
                        root.row-menu-aid = acc.id;
                        root.row-menu-active = acc.is-active;
                        root.row-menu-x = self.absolute-position.x - root.absolute-position.x + rx;
                        root.row-menu-y = self.absolute-position.y - root.absolute-position.y + ry;
                        root.row-menu-open = true;
                        root.window-menu-open = false;
                    }
                }
            }

            // ── Auto-switch checkbox (text label, 10px like Python) ──
            TinyCheckBox {
                checked: root.auto-switch-enabled;
                text: "Авто-переключение при исчерпании квоты";
                toggled => { root.toggle-auto-switch(); }
            }
        }

        // ── Compact mode: single row with active-account % + 3 buttons. ──
        // Absolute positioning so children are vertically centered regardless
        // of how the OS resizes the window. Tap on % toggles back; drag works
        // anywhere on the row via pointer-event(down)→drag-start.
        if root.compact-mode : Rectangle {
            x: 0; y: 0; width: 100%; height: 100%;
            background: transparent;

            // % label — fills the left side of the row.
            Rectangle {
                x: 6px;
                y: 0;
                width: parent.width - 6px - 4px - 16px - 4px - 16px - 4px - 16px - 6px;
                height: parent.height;
                background: transparent;
                Text {
                    width: 100%; height: 100%;
                    text: root.compact-text;
                    color: #e0e0e0;
                    font-size: 11px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                }
                compact_touch := TouchArea {
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                            root.drag-start();
                        }
                    }
                    clicked => { root.compact-exit-clicked(); }
                }
            }

            // Refresh button — first of three buttons, anchored from the right.
            Rectangle {
                x: parent.width - 16px - 4px - 16px - 4px - 16px - 6px;
                y: (parent.height - 16px) / 2;
                width: 16px; height: 16px;
                background: transparent;
                cr_touch := TouchArea {
                    clicked => { root.refresh-clicked(); }
                }
                property <int> spin-tick: 0;
                Timer {
                    interval: 40ms;
                    running: root.is-refreshing && root.compact-mode;
                    triggered => {
                        parent.spin-tick = parent.spin-tick + 12 >= 360
                            ? 0
                            : parent.spin-tick + 12;
                    }
                }
                Image {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    width: 12px; height: 12px;
                    source: @image-url("refresh.svg");
                    colorize: root.is-refreshing
                        ? #60a5fa
                        : (cr_touch.has-hover ? #ffffff : #cccccc);
                    rotation-origin-x: self.width / 2;
                    rotation-origin-y: self.height / 2;
                    rotation-angle: parent.spin-tick * 1deg;
                }
            }

            // Minimize and close — fixed 16×16 buttons, vertically centered.
            HeaderButton {
                x: parent.width - 16px - 4px - 16px - 6px;
                y: (parent.height - 16px) / 2;
                glyph: "–";
                clicked => { root.minimize-clicked(); }
            }
            HeaderButton {
                x: parent.width - 16px - 6px;
                y: (parent.height - 16px) / 2;
                glyph: "✕";
                font-size: 12px;
                hover-color: #f87171;
                clicked => { root.close-clicked(); }
            }
        }
    }

    // ─────────────────── window context menu (popup) ───────────────────
    if root.window-menu-open : Rectangle {
        // backdrop catches outside-clicks
        background: transparent;
        TouchArea {
            clicked => { root.window-menu-open = false; }
        }
    }
    if root.window-menu-open : Rectangle {
        // Menu has 7 items × 22px + 2 separators × 7px + padding 4px ≈ 172px.
        // Cap at 180. Position never less than 5px from window top so the
        // top items stop getting clipped when the click was near the title bar.
        x: min(root.window-menu-x + 5px, root.width - 200px);
        y: max(5px, min(root.window-menu-y + 5px, root.height - 180px));
        width: 200px;
        height: 180px;
        background: #1a1a1a;
        border-width: 1px;
        border-color: #333333;
        border-radius: 4px;
        drop-shadow-blur: 8px;
        drop-shadow-color: rgba(0, 0, 0, 0.6);
        VerticalLayout {
            padding: 2px;
            spacing: 0px;
            MenuRow { label: "Обновить";                activated => { root.window-menu-open = false; root.refresh-clicked(); } }
            MenuRow { label: "Обновить все аккаунты";   activated => { root.window-menu-open = false; root.refresh-all-clicked(); } }
            MenuRow { label: "Claude Status";           activated => { root.window-menu-open = false; root.open-claude-status(); } }
            MenuRow { label: "Свернуть в трей";         activated => { root.window-menu-open = false; root.minimize-clicked(); } }
            MenuRow { separator: true; }
            MenuRow { label: "Войти снова";             activated => { root.window-menu-open = false; root.relogin-clicked(); } }
            MenuRow { label: root.proxy-label;          activated => { root.window-menu-open = false; root.configure-proxy-clicked(); } }
            MenuRow { separator: true; }
            MenuRow { label: "Выйти";                   activated => { root.window-menu-open = false; root.quit-clicked(); } }
        }
    }

    // ─────────────────── row context menu (popup) ───────────────────
    if root.row-menu-open : Rectangle {
        background: transparent;
        TouchArea {
            clicked => { root.row-menu-open = false; }
        }
    }
    if root.row-menu-open : Rectangle {
        x: min(root.row-menu-x + 5px, root.width - 200px);
        y: min(root.row-menu-y + 5px, root.height - 70px);
        width: 200px;
        height: root.row-menu-active ? 30px : 60px;
        background: #1a1a1a;
        border-width: 1px;
        border-color: #333333;
        border-radius: 4px;
        drop-shadow-blur: 8px;
        drop-shadow-color: rgba(0, 0, 0, 0.6);
        VerticalLayout {
            padding: 2px;
            spacing: 0px;
            if !root.row-menu-active : MenuRow {
                label: "Переключиться на этот аккаунт";
                activated => {
                    root.row-menu-open = false;
                    root.row-activated(root.row-menu-aid);
                }
            }
            if !root.row-menu-active : MenuRow { separator: true; }
            MenuRow {
                label: "Удалить из списка";
                activated => {
                    root.row-menu-open = false;
                    root.row-remove(root.row-menu-aid);
                }
            }
        }
    }
}
