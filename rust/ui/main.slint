// ClaudeMonitor overlay — frameless dark window with three top metrics
// and a per-account table. Rendered by Skia via Slint's default backend.

import { ScrollView, Button, CheckBox } from "std-widgets.slint";

// ─────────────────────────── data structures ────────────────────────────────

export struct MetricView {
    label: string,
    pct: float,             // 0..100+
    pct-text: string,       // pre-formatted "85%"
    reset-text: string,     // "in 1h 23m" or "—"
    color: color,           // status colour
    has-data: bool,
}

export struct AccountView {
    id: string,
    email: string,          // shown
    email-full: string,     // tooltip
    plan: string,
    five-hour: MetricView,
    seven-day: MetricView,
    seven-day-design: MetricView,
    is-active: bool,
}

export struct StatusView {
    text: string,
    error: bool,
    visible: bool,
}

// ─────────────────────────── reusable bits ──────────────────────────────────

component MetricCell inherits Rectangle {
    in property <MetricView> metric;
    width: 84px;
    background: transparent;
    VerticalLayout {
        alignment: center;
        spacing: 2px;
        Text {
            text: metric.has-data ? metric.pct-text : "—";
            color: metric.has-data ? metric.color : #666666;
            horizontal-alignment: center;
            font-size: 14px;
            font-weight: 600;
        }
        Text {
            text: metric.has-data ? metric.reset-text : "";
            color: #707070;
            horizontal-alignment: center;
            font-size: 9px;
        }
    }
}

component CheckCircle inherits Rectangle {
    in property <bool> active;
    in property <bool> hovered;
    width: 18px;
    height: 18px;

    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        border-width: 1.5px;
        border-color: active ? #4ade80 : (hovered ? #4ade80 : #555555);
        background: active ? #4ade80 : transparent;

        // Drawn check (rotated rectangles) — only visible when active.
        if active : Path {
            stroke: #0a0a0a;
            stroke-width: 2px;
            fill: transparent;
            commands: "M 4 8 L 7 11 L 12 5";
        }
    }
}

component AccountRow inherits Rectangle {
    in property <AccountView> account;
    in-out property <bool> hovered;

    callback row-clicked();
    callback remove-clicked();

    height: 36px;
    background: account.is-active ? #1a1a26 : (hovered ? #14141c : transparent);
    border-radius: 4px;

    touch := TouchArea {
        clicked => { root.row-clicked(); }
        mouse-cursor: pointer;
        changed has-hover => { root.hovered = self.has-hover; }
    }

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;
        alignment: stretch;

        // Active marker
        Rectangle {
            width: 24px;
            CheckCircle {
                active: account.is-active;
                hovered: root.hovered;
            }
        }

        // Email (truncated to 6 chars). Tooltip via title (Slint native ToolTip is not stable on 1.9 — fallback: show full on hover at row level).
        Rectangle {
            width: 92px;
            Text {
                text: account.email;
                color: #d0d0d0;
                font-size: 11px;
                vertical-alignment: center;
                horizontal-alignment: left;
                overflow: elide;
            }
        }

        // Plan badge
        Rectangle {
            width: 50px;
            Text {
                text: account.plan;
                color: #ff9d5c;
                font-size: 10px;
                vertical-alignment: center;
                horizontal-alignment: left;
            }
        }

        MetricCell { metric: account.five-hour; }
        MetricCell { metric: account.seven-day; }
        MetricCell { metric: account.seven-day-design; }
    }
}

// ─────────────────────────── main window ────────────────────────────────────

export component AppWindow inherits Window {
    title: "ClaudeMonitor";
    width: 460px;
    height: 320px;
    background: #0c0c0c;
    no-frame: true;
    always-on-top: true;
    icon: @image-url("");

    in property <[AccountView]> accounts: [];
    in property <MetricView> top-five-hour;
    in property <MetricView> top-seven-day;
    in property <MetricView> top-seven-day-design;
    in property <StatusView> status: { text: "", error: false, visible: false };
    in property <bool> auto-switch-enabled: false;
    in property <string> last-update-text: "—";

    callback close-clicked();
    callback minimize-clicked();
    callback add-account-clicked();
    callback row-activated(string /* account id */);
    callback toggle-auto-switch();
    callback refresh-clicked();

    Rectangle {
        background: #0c0c0c;
        border-radius: 8px;
        border-width: 1px;
        border-color: #2a2a3a;

        VerticalLayout {
            padding: 10px;
            spacing: 8px;

            // ── Title bar with close button ──
            HorizontalLayout {
                alignment: space-between;
                Text {
                    text: "Claude Monitor";
                    color: #e0e0e0;
                    font-size: 13px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
                HorizontalLayout {
                    spacing: 6px;
                    TouchArea {
                        width: 22px; height: 22px;
                        clicked => { root.refresh-clicked(); }
                        mouse-cursor: pointer;
                        Text {
                            text: "↻";
                            color: parent.has-hover ? #ffffff : #888888;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        width: 22px; height: 22px;
                        clicked => { root.minimize-clicked(); }
                        mouse-cursor: pointer;
                        Text {
                            text: "—";
                            color: parent.has-hover ? #ffffff : #888888;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        width: 22px; height: 22px;
                        clicked => { root.close-clicked(); }
                        mouse-cursor: pointer;
                        Text {
                            text: "×";
                            color: parent.has-hover ? #ff7a7a : #888888;
                            font-size: 16px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // ── Three top metrics ──
            Rectangle {
                height: 56px;
                background: #14141c;
                border-radius: 6px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    alignment: space-around;
                    Rectangle { width: 1px; }
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: top-five-hour.label;
                            color: #888888;
                            font-size: 10px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: top-five-hour.has-data ? top-five-hour.pct-text : "—";
                            color: top-five-hour.has-data ? top-five-hour.color : #666666;
                            font-size: 18px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: top-five-hour.has-data ? top-five-hour.reset-text : "";
                            color: #666666;
                            font-size: 9px;
                            horizontal-alignment: center;
                        }
                    }
                    Rectangle { width: 1px; background: #2a2a3a; }
                    VerticalLayout {
                        alignment: center;
                        Text { text: top-seven-day.label; color: #888888; font-size: 10px; horizontal-alignment: center; }
                        Text {
                            text: top-seven-day.has-data ? top-seven-day.pct-text : "—";
                            color: top-seven-day.has-data ? top-seven-day.color : #666666;
                            font-size: 18px; font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text { text: top-seven-day.has-data ? top-seven-day.reset-text : ""; color: #666666; font-size: 9px; horizontal-alignment: center; }
                    }
                    Rectangle { width: 1px; background: #2a2a3a; }
                    VerticalLayout {
                        alignment: center;
                        Text { text: top-seven-day-design.label; color: #888888; font-size: 10px; horizontal-alignment: center; }
                        Text {
                            text: top-seven-day-design.has-data ? top-seven-day-design.pct-text : "—";
                            color: top-seven-day-design.has-data ? top-seven-day-design.color : #666666;
                            font-size: 18px; font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text { text: top-seven-day-design.has-data ? top-seven-day-design.reset-text : ""; color: #666666; font-size: 9px; horizontal-alignment: center; }
                    }
                    Rectangle { width: 1px; }
                }
            }

            // ── Accounts table ──
            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 2px;
                    for acc in accounts : AccountRow {
                        account: acc;
                        row-clicked => { root.row-activated(acc.id); }
                    }
                }
            }

            // ── Bottom toolbar ──
            HorizontalLayout {
                spacing: 6px;
                alignment: space-between;
                TouchArea {
                    width: 110px; height: 26px;
                    clicked => { root.add-account-clicked(); }
                    mouse-cursor: pointer;
                    Rectangle {
                        background: parent.has-hover ? #ff7a2f : #2a2a3a;
                        border-radius: 4px;
                        Text {
                            text: "+ Добавить";
                            color: #ffffff;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    Text {
                        text: status.visible ? status.text : "обновлено: " + last-update-text;
                        color: status.error ? #f87171 : #707070;
                        font-size: 10px;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                    }
                }
                TouchArea {
                    width: 22px; height: 22px;
                    mouse-cursor: pointer;
                    clicked => { root.toggle-auto-switch(); }
                    Rectangle {
                        background: auto-switch-enabled ? #4ade80 : #2a2a3a;
                        border-radius: 4px;
                        Text {
                            text: "A";
                            color: auto-switch-enabled ? #0c0c0c : #888888;
                            font-size: 11px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
